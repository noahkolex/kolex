# ─────────────────────────────────────────────────────────────────────────
# Kolex configuration. Copy to `.env` and fill in. Everything is optional —
# with no Stripe keys the server runs in STUB mode (full flow, no real money),
# so you can test end to end immediately. Add real keys to go live.
# ─────────────────────────────────────────────────────────────────────────

# ── Server ──
PORT=4000
# Public base URL of this server (used for Stripe redirect + webhook URLs).
# Leave blank to infer from the incoming request (fine for local dev).
SITE_BASE=

# ── Database ──
# When DATABASE_URL is set, Kolex stores everything in Postgres (durable across
# restarts/redeploys). On Railway, add a Postgres database and this is injected
# automatically — no other setup. Leave blank for local dev: it falls back to a
# JSON file at server/data/db.json.
DATABASE_URL=
# SSL is enabled automatically for non-local hosts. Set to "disable" only for a
# local Postgres without TLS.
# PGSSLMODE=

# ── Stripe ──
# Get these from https://dashboard.stripe.com/apikeys (use the TEST keys first).
# With no secret key, payments run in STUB mode automatically.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From `stripe listen` or the Dashboard webhook endpoint signing secret.
STRIPE_WEBHOOK_SECRET=
# usd, eur, gbp, ...
STRIPE_CURRENCY=usd
# Force a mode: auto (default) | stub | live
STRIPE_MODE=auto
# Real user payouts require Stripe Connect. Off by default (payouts recorded).
STRIPE_ENABLE_PAYOUTS=false
# Optional: pin the Stripe API version.
STRIPE_API_VERSION=

# Minimum balance (USD) a user must accrue before they can cash out.
KOLEX_MIN_PAYOUT_USD=10

# ── Abuse / incident controls (all hot-toggleable via env) ──
# Globally pause ALL cash-outs (balances are kept). Flip to 1 during an incident.
KOLEX_PAYOUTS_HALTED=0
# Suspend click revenue (the 50× vector) — clicks then earn + bill nothing.
KOLEX_DISABLE_CLICKS=0
# Max a single device can earn per rolling hour (USD). 0 = no cap.
KOLEX_HOURLY_CAP_USD=5
# Impressions/min above this are physically impossible → dropped + flagged.
KOLEX_MAX_IMPRESSIONS_PER_MIN=20
# Auto-ban a device after this many flags.
KOLEX_AUTOBAN_FLAGS=3
# Max events accepted per /v1/events POST (overflow ignored).
KOLEX_MAX_EVENTS_PER_BATCH=200
# Bearer token for /api/admin/ban, /api/admin/unban, /api/admin/suspicious.
KOLEX_ADMIN_TOKEN=

# ── Analytics (PostHog, optional) ──
# The project API key (phc_…) is safe to expose, so the same key powers server,
# website, and extension capture. Leave blank to disable analytics everywhere.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Transactional email (password reset links) ──
# With a Resend API key, reset links are actually emailed. Without one, the
# link is logged to the server console (and returned in the API response in
# non-production) so the flow is still testable.
RESEND_API_KEY=
# The "From" address. Use Resend's onboarding@resend.dev for quick tests, or a
# verified domain in production.
KOLEX_EMAIL_FROM=Kolex <onboarding@resend.dev>

# ── Chrome extension build (consumed by `npm run build`) ──
# Where the extension talks to. For local testing point it at this server.
KOLEX_API_BASE=https://api.kolex.ai/v1
KOLEX_SITE_BASE=https://kolex.ai
# Local testing example:
#   KOLEX_API_BASE=http://localhost:4000/v1
#   KOLEX_SITE_BASE=http://localhost:4000
