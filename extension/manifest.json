{
  "manifest_version": 3,
  "name": "Kolex — get paid for waiting",
  "version": "0.5.0",
  "description": "Replaces the loading indicators on ChatGPT, Claude, Gemini, and Grok with one sponsored status line. You keep 50% of the ad revenue.",
  "homepage_url": "https://kolex.ai",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kolex"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://api.kolex.ai/*"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://twitter.com/i/grok*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
